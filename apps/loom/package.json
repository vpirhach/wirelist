{
  "name": "@wirelist/loom",
  "version": "1.0.0",
  "description": "Loom - Wire list document extractor with automatic column detection",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "string-similarity": "^4.0.4",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.0",
    "@types/string-similarity": "^4.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
