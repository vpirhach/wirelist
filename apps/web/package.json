    "eslint-plugin-vue": "^9.32.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "naive-ui": "^2.41.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.1",
    "start-server-and-test": "^2.0.10",
    "tailwindcss": "^4.0.12",
    "typescript": "~5.7.3",
