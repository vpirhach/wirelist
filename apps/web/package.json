    "swiper": "^11.2.1",
    "vue": "^3.5.13",
    "vue-flatpickr-component": "^11.0.5",
    "vue-i18n": "^9.14.3",
    "vue-kanban": "^1.8.0",
    "vue-router": "^4.5.0",
    "vue3-apexcharts": "^1.8.0",
    "vuedraggable": "^4.1.0",
    "vuevectormap": "^2.0.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/cytoscape": "^3.21.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.4",
