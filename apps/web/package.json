    "@fullcalendar/timegrid": "^6.1.15",
    "@fullcalendar/vue3": "^6.1.15",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.12",
    "apexcharts": "^4.4.0",
    "axios": "^1.8.2",
    "cytoscape": "^3.33.1",
    "dropzone": "^6.0.0-beta.2",
    "flatpickr": "^4.6.13",
    "flowbite": "^3.1.2",
    "flowbite-vue": "^0.1.9",
    "jsvectormap": "^1.6.0",
    "lucide-vue-next": "^0.474.0",
    "pinia": "^3.0.1",
