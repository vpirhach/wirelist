# Copy to `.env` and adjust. Values below are examples only.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5436/wirelist_db?schema=public"

# Server
PORT=3002
NODE_ENV=development

# JWT
JWT_SECRET=change-me
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3002

# File upload
MAX_FILE_SIZE=52428800

# Loom (apps/loom) — required for wire-list import (POST /api/loom-upload/*)
# Local: http://localhost:3050
# Docker Compose (service name): http://loom:3050
LOOM_BASE_URL=http://localhost:3050
